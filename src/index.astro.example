---
/**
 * Example homepage usage — shows how to query the collection
 * and compute stats at build time.
 *
 * This file is for reference; adapt it to your actual layout.
 */
import { getCollection } from "astro:content";
import { computeStats, filterByCategory } from "../lib/pardon-stats";

const allGrants = await getCollection("pardonDetails");
const stats = computeStats(allGrants);

// Category-specific subsets for drill-down sections
const fraudGrants = filterByCategory(allGrants, "fraud");
const faceActGrants = filterByCategory(allGrants, "FACE act");
---

<html lang="en">
  <body>
    <section>
      <h1>Pardonned</h1>
      <p>Tracking clemency grants under the Trump (Term 2) administration.</p>

      <dl>
        <dt>Total Clemency Grants</dt>
        <dd>{stats.totalGrants}</dd>

        <dt>Pardons</dt>
        <dd>{stats.totalPardons}</dd>

        <dt>Commutations</dt>
        <dd>{stats.totalCommutations}</dd>

        <dt>Prison Time Erased</dt>
        <dd>{stats.totalYearsErased} years ({stats.totalMonthsErased} months)</dd>

        <dt>Life Sentences Pardoned</dt>
        <dd>{stats.lifeSentenceCount}</dd>

        <dt>Restitution Abandoned</dt>
        <dd>${stats.totalRestitutionAbandoned.toLocaleString()}</dd>

        <dt>Fines Abandoned</dt>
        <dd>${stats.totalFinesAbandoned.toLocaleString()}</dd>

        <dt>Fraud-Related Grants</dt>
        <dd>{stats.fraudCount}</dd>
      </dl>
    </section>

    <section>
      <h2>By Category</h2>
      <ul>
        {Object.entries(stats.byCategory).map(([cat, count]) => (
          <li>{cat}: {count}</li>
        ))}
      </ul>
    </section>

    <section>
      <h2>All Recipients</h2>
      <ul>
        {allGrants.map((entry) => (
          <li>
            <strong>{entry.data.recipient_name}</strong> —
            {entry.data.clemency_type} ({entry.data.grant_date}) —
            {entry.data.offense_category}: {entry.data.offense}
          </li>
        ))}
      </ul>
    </section>
  </body>
</html>
