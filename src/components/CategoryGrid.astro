---
import CategoryCard from './CategoryCard.astro';

interface CategoryCount {
  key: string;
  name: string;
  count: number;
  color?: string;
}

interface Props {
  categoryCounts: CategoryCount[];
  columns?: 2 | 3;
  hrefPattern?: string;
}

const { categoryCounts, columns = 3, hrefPattern } = Astro.props;

const sortedCategories = [...categoryCounts].sort((a, b) => b.count - a.count);

const gridClasses = columns === 2 ? 'grid-cols-2' : 'grid-cols-3';
---

<div class:list={['grid gap-grid', gridClasses]}>
  {sortedCategories.map(({ key, name, count, color }) => (
    <CategoryCard
      name={name}
      count={count}
      color={color}
      href={hrefPattern?.replace('{key}', key)}
    />
  ))}
</div>
