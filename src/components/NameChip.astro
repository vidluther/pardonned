---
interface Props {
  name: string;
  href?: string;
  type?: "pardon" | "commutation";
}

const { name, href, type } = Astro.props;
const variantClass =
  type === "commutation"
    ? "name-chip--commutation"
    : type === "pardon"
      ? "name-chip--pardon"
      : "";
---

{href ? (
  <a
    href={href}
    class:list={["name-chip", "name-chip-link", "no-underline", variantClass]}
  >
    {name}
  </a>
) : (
  <span class:list={["name-chip", variantClass]}>{name}</span>
)}
