---
interface Props {
  name: string;
  count: number;
  color?: string;
  href?: string;
}

const { name, count, color = '#7A7880', href } = Astro.props;

const CardWrapper = href ? 'a' : 'div';
---

<CardWrapper 
  href={href}
  class:list={[
    'category-card',
    href && 'hover:bg-muted transition-colors'
  ]}
  style={`border-left-color: ${color};`}
>
  <span class="category-count" style={`color: ${color};`}>
    {count.toLocaleString()}
  </span>
  <span class="text-nav text-text-body">{name}</span>
</CardWrapper>
