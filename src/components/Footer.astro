---
import { siteConfig, mainNavigation } from '../config/navigation';

interface Props {
  showNav?: boolean;
}

const { showNav = true } = Astro.props;
---

<footer class="border-t border-border-DEFAULT mt-16">
  <div class="max-w-home mx-auto px-10 py-8">
    <!-- Logo -->
    <div class="flex items-baseline gap-3 mb-4">
      <a href="/" class="no-underline hover:opacity-80 transition-opacity">
        <span class="wordmark-footer">
          Pardonn<span class="wordmark-accent">e</span>d
        </span>
      </a>
    </div>

    <!-- Optional Footer Navigation -->
    {showNav && (
      <nav class="flex gap-6 mb-4">
        {mainNavigation.map((item) => (
          <a
            href={item.href}
            class="text-nav text-text-muted hover:text-text-primary transition-colors"
          >
            {item.label}
          </a>
        ))}
      </nav>
    )}

    <!-- Source Attribution -->
    <p class="text-meta text-text-ghost">
      Data source: {siteConfig.dataSource} · {siteConfig.disclaimer}
    </p>
  </div>
</footer>
