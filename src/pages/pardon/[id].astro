---
import Layout from '../../layouts/Layout.astro';
import TypeBadge from '../../components/TypeBadge.astro';
import CategoryBadge from '../../components/CategoryBadge.astro';
import StatCard from '../../components/StatCard.astro';
import '../../styles/global.css';
import { type CategoryKey } from '../../config/categories';

interface Props {
  id: string;
}

const { id } = Astro.props;

const currentPath = Astro.url.pathname;

const GRANT = {
  name: 'Todd Chrisley',
  type: 'pardon' as const,
  date: 'May 28, 2025',
  district: 'Northern District of Georgia',
  districtShort: 'N.D. Ga.',
  warrantUrl: 'https://www.justice.gov/pardon/media/1401921/dl?inline',
  sourceUrl: 'https://www.justice.gov/pardon/clemency-grants-president-donald-j-trump-2025-present',
  sentence: "144 months' imprisonment; three years' supervised release; $17,270,741.57 restitution",
  sentenceParsed: {
    imprisonment: '144 months (12 years)',
    supervisedRelease: '3 years',
    restitution: '$17,270,741.57',
    sentencingDate: 'November 21, 2022',
  },
  offenses: [
    'Conspiracy to commit bank fraud',
    'Bank fraud (five counts)',
    'Conspiracy to defraud the U.S. to obstruct and impede the Internal Revenue Laws',
    'Tax evasion',
  ],
  category: 'fraud' as CategoryKey,
  summary:
    "Todd Chrisley, known for the reality television show 'Chrisley Knows Best,' was convicted in 2022 alongside his wife Julie Chrisley of defrauding community banks out of more than $30 million in fraudulent loans. The couple also evaded federal taxes and obstructed an IRS investigation. The restitution order of over $17 million was owed to the defrauded banks.",
};

const RELATED = [
  {
    name: 'Julie Chrisley',
    type: 'pardon' as const,
    date: 'May 28, 2025',
    offense: 'Bank fraud; wire fraud; tax evasion; obstruction of justice',
    restitution: '$4,740,645.04',
    sentence: "84 months' imprisonment",
    relation: 'Co-defendant, spouse',
  },
];

const TIMELINE = [
  { date: 'Jun 2019', event: 'Indicted on federal charges in the Northern District of Georgia' },
  { date: 'Jun 2022', event: 'Found guilty by a federal jury on all counts' },
  { date: 'Nov 2022', event: "Sentenced to 144 months' imprisonment and $17.2M restitution" },
  { date: 'Jan 2024', event: 'Reported to FPC Pensacola to begin sentence' },
  { date: 'May 28, 2025', event: 'Granted full presidential pardon', highlight: true },
];

export async function getStaticPaths() {
  return [{ params: { id: '1' } }];
}
---

<Layout 
  title={GRANT.name}
  currentPath={currentPath}
>
  <div class="max-w-detail mx-auto px-10 py-10">
    <!-- Breadcrumb -->
    <div class="breadcrumb mb-6">
      <a href="/search" class="text-text-muted no-underline hover:text-text-primary transition-colors">Search</a>
      <span class="text-border-soft">/</span>
      <span class="text-text-body">{GRANT.name}</span>
    </div>

    <!-- Header -->
    <div class="mb-10">
      <div class="flex items-center gap-3 mb-3">
        <TypeBadge type={GRANT.type} />
        <CategoryBadge category={GRANT.category} />
        <span class="text-meta text-text-faint">Granted {GRANT.date}</span>
      </div>

      <h1 class="font-serif text-text-primary mb-3" style="font-size: 42px; line-height: 1.15; letter-spacing: -0.02em;">
        {GRANT.name}
      </h1>

      <p class="text-body text-text-faint m-0 mb-6">
        {GRANT.districtShort} · Sentenced {GRANT.sentenceParsed.sentencingDate}
      </p>

      <!-- Stat cards -->
      <div class="grid grid-cols-3 gap-3">
        <StatCard
          label="Restitution abandoned"
          value={GRANT.sentenceParsed.restitution}
          footnote="Owed to defrauded banks"
          variant="restitution"
        />
        <StatCard
          label="Prison sentence"
          value="12 years"
          footnote="144 months originally imposed"
        />
        <StatCard
          label="Charges"
          value={String(GRANT.offenses.length)}
          footnote="Including 5 counts of bank fraud"
        />
      </div>
    </div>

    <!-- Tabs -->
    <div class="tab-nav" id="detail-tabs">
      <button class="tab tab-active" data-tab="overview">Overview</button>
      <button class="tab tab-inactive" data-tab="offenses">Offenses</button>
      <button class="tab tab-inactive" data-tab="timeline">Timeline</button>
      <button class="tab tab-inactive" data-tab="related">Related</button>
    </div>

    <!-- Tab Content: Overview -->
    <div id="tab-overview" class="tab-content">
      <p class="text-body text-text-body mb-8 max-w-2xl leading-relaxed">
        {GRANT.summary}
      </p>

      <!-- Sentence Details -->
      <div class="bg-card border border-border-DEFAULT rounded-card p-6 mb-6">
        <h3 class="text-nav font-medium text-text-faint mb-4 uppercase tracking-wide" style="letter-spacing: 0.08em;">Sentence details</h3>
        <div class="grid grid-cols-2 gap-x-10 gap-y-4">
          {Object.entries(GRANT.sentenceParsed).map(([key, val]) => (
            <div>
              <div class="text-meta text-text-faint mb-1 capitalize">{key.replace(/([A-Z])/g, ' $1').trim()}</div>
              <div class="text-body" style={`color: ${key === 'restitution' ? '#C23B22' : '#1A1918'}; font-weight: ${key === 'restitution' ? 500 : 400};`}>
                {val}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Source Documents -->
      <div class="bg-card border border-border-DEFAULT rounded-card p-6">
        <h3 class="text-nav font-medium text-text-faint mb-4 uppercase tracking-wide" style="letter-spacing: 0.08em;">Source documents</h3>
        <div class="flex flex-col gap-3">
          <a 
            href={GRANT.warrantUrl} 
            target="_blank" 
            rel="noopener"
            class="source-link no-underline hover:bg-muted transition-colors"
          >
            <span class="text-xl opacity-50">📄</span>
            <div>
              <div class="text-nav text-text-primary mb-0.5">Pardon warrant (PDF)</div>
              <div class="text-meta text-text-faint">DOJ Office of the Pardon Attorney</div>
            </div>
            <span class="text-faint ml-auto">↗</span>
          </a>
          <a 
            href={GRANT.sourceUrl} 
            target="_blank" 
            rel="noopener"
            class="source-link no-underline hover:bg-muted transition-colors"
          >
            <span class="text-xl opacity-50">🏛</span>
            <div>
              <div class="text-nav text-text-primary mb-0.5">DOJ clemency listing page</div>
              <div class="text-meta text-text-faint">justice.gov/pardon</div>
            </div>
            <span class="text-faint ml-auto">↗</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Tab Content: Offenses -->
    <div id="tab-offenses" class="tab-content hidden">
      <p class="text-nav text-text-muted mb-6">
        Federal charges for which clemency was granted, as listed on the DOJ warrant document.
      </p>
      <div class="flex flex-col gap-2">
        {GRANT.offenses.map((offense, i) => (
          <div class="offense-item">
            <span class="text-meta font-medium text-text-faint bg-muted rounded-badge px-2 py-0.5 text-center min-w-5">
              {i + 1}
            </span>
            <div>
              <div class="text-body text-text-primary mb-1">{offense}</div>
              <div class="text-meta text-text-faint">
                {offense.includes('bank fraud') && offense.includes('five') 
                  ? 'Five separate counts' 
                  : offense.includes('Conspiracy') 
                    ? 'Federal conspiracy charge' 
                    : offense.includes('Tax') 
                      ? 'Federal tax offense' 
                      : 'Federal offense'}
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-6 px-5 py-4 border rounded-card text-sm leading-relaxed" style="background: rgba(138,107,30,0.05); border-color: rgba(138,107,30,0.15); color: #7A6A30;">
        Full original sentence: {GRANT.sentence}
      </div>
    </div>

    <!-- Tab Content: Timeline -->
    <div id="tab-timeline" class="tab-content hidden">
      <div class="timeline-container">
        <div class="timeline-line"></div>
        {TIMELINE.map((t) => (
          <div class="relative mb-8 pl-6">
            <div
              class:list={[
                'timeline-dot absolute -left-8 top-1',
                t.highlight ? 'timeline-dot-active' : ''
              ]}
            ></div>
            <div class="text-meta text-text-faint mb-1 font-medium">{t.date}</div>
            <div class="text-body" style={`color: ${t.highlight ? '#1A1918' : '#5A5850'}; font-weight: ${t.highlight ? 500 : 400};`}>
              {t.event}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Tab Content: Related -->
    <div id="tab-related" class="tab-content hidden">
      <p class="text-nav text-text-muted mb-6">
        Other clemency grants connected to this case or individual.
      </p>
      {RELATED.map((r) => (
        <div class="bg-card border border-border-DEFAULT rounded-card p-6 mb-3 cursor-pointer hover:bg-muted transition-colors">
          <div class="flex items-center gap-2.5 mb-2.5">
            <span class="text-card-title font-medium text-text-primary">{r.name}</span>
            <TypeBadge type={r.type} />
            <span class="badge" style="background: rgba(42,106,122,0.08); color: #2A6A7A;">{r.relation}</span>
          </div>
          <p class="text-card-offense text-text-secondary m-0 mb-2.5">{r.offense}</p>
          <div class="flex gap-6 text-meta text-text-faint">
            <span>Granted {r.date}</span>
            <span>{r.sentence}</span>
            <span class="text-accent">{r.restitution} restitution</span>
          </div>
        </div>
      ))}

      <!-- Combined Impact Callout -->
      <div class="impact-callout mt-6">
        <h4 class="text-nav font-medium text-accent mb-3 uppercase" style="letter-spacing: 0.06em;">
          Combined impact of related grants
        </h4>
        <div class="grid grid-cols-3 gap-4">
          <div>
            <div class="text-badge mb-1 uppercase" style="color: #A07060;">Total restitution</div>
            <div class="text-impact font-medium text-accent font-serif">$22,011,386</div>
          </div>
          <div>
            <div class="text-badge text-text-faint mb-1 uppercase">Combined sentences</div>
            <div class="text-impact font-medium text-text-primary font-serif">19 years</div>
          </div>
          <div>
            <div class="text-badge text-text-faint mb-1 uppercase">Individuals pardoned</div>
            <div class="text-impact font-medium text-text-primary font-serif">2</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const tabs = document.querySelectorAll('#detail-tabs .tab');
      const contents = document.querySelectorAll('.tab-content');

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const target = tab.getAttribute('data-tab');

          tabs.forEach((t) => {
            t.classList.remove('tab-active');
            t.classList.add('tab-inactive');
          });
          tab.classList.remove('tab-inactive');
          tab.classList.add('tab-active');

          contents.forEach((content) => {
            content.classList.add('hidden');
          });
          const targetContent = document.getElementById('tab-' + target);
          if (targetContent) {
            targetContent.classList.remove('hidden');
          }
        });
      });
    });
  </script>
</Layout>
