---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SeoHead from "../components/SeoHead.astro";
import Analytics from "../components/Analytics.astro";
import PostHog from "../components/PostHog.astro";
import { siteConfig } from "../config/site";
import { truncateText } from "../lib/seo";

interface Props {
    title?: string;
    description?: string;
    ogImage?: string;
    showHeader?: boolean;
    showFooter?: boolean;
    currentPath?: string;
}

const {
    title = siteConfig.name,
    description = siteConfig.description,
    ogImage,
    showHeader = true,
    showFooter = true,
    currentPath = "/",
} = Astro.props;

let fullTitle;
if (title === siteConfig.name) {
    fullTitle = title;
} else {
    fullTitle = `${title} — ${siteConfig.name}`;
}

const metaDescription = truncateText(description, 160);
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <meta name="description" content={metaDescription} />
        <link rel="canonical" href={Astro.url?.toString()} />

        <SeoHead title={fullTitle} description={description} ogImage={ogImage} />

        <!-- Google Fonts - DM Sans + DM Serif Display -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            rel="stylesheet"
            href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500&family=DM+Serif+Display&display=swap"
        />

        <Analytics />
        <PostHog />
        <title>{fullTitle}</title>
    </head>
    <body
        class="bg-page font-sans text-body antialiased min-h-screen flex flex-col"
    >
        <a href="#main-content" class="skip-link">Skip to content</a>
        {showHeader && <Header currentPath={currentPath} />}

        <main id="main-content" class="flex-1">
            <slot />
        </main>

        {showFooter && <Footer />}
    </body>
</html>
